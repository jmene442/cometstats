# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API

# Public keys — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Secret key — server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── App ───────────────────────────────────────────────────────────────────────
# Used for cookie signing / session security. Generate a random 32+ char string.
# Example: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here

# The public URL of your app (used for redirects after login)
NEXT_PUBLIC_APP_URL=http://localhost:3000
